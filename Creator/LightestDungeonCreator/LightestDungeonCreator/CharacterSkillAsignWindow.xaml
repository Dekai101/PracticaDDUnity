<Window x:Class="LightestDungeonCreator.CharacterSkillAssignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Character Skills"
        Height="880" Width="860"
        MinHeight="600" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#120C06"/>
            <Setter Property="Foreground"      Value="#D4C5A9"/>
            <Setter Property="BorderBrush"     Value="#5C3A1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontFamily"      Value="Georgia"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8922A"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C8922A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="Bold"/>
        </Style>

        <Style x:Key="SectionPanel" TargetType="Border">
            <Setter Property="Background"      Value="#110D07"/>
            <Setter Property="BorderBrush"     Value="#5C3A1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="Margin"          Value="0,10,0,0"/>
        </Style>

        <Style x:Key="SmallMuted" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5C3A1E"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
        </Style>

        <Style x:Key="StatReadOnly" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C8922A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatName" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,0,6,0"/>
        </Style>

        <Style x:Key="RemoveBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#5C3A1E"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="T" Text="✕" Foreground="{TemplateBinding Foreground}"
                                   FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="T" Property="Foreground" Value="#CC3333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddSkillBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1F1208"/>
            <Setter Property="BorderBrush"     Value="#8A6015"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#C8922A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontFamily"      Value="Georgia"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#3A2210"/>
                                <Setter TargetName="R" Property="BorderBrush" Value="#C8922A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,3,10,3"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#C8922A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#8A6015"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,8,0,4"/>
        </Style>

        <Style x:Key="GoldSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#8A6015" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#2A1A08" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="20" CornerRadius="2"
                                                        Background="#C8922A" BorderBrush="#8A6015" BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#C8922A" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D2210">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0A08" Offset="0"/>
                <GradientStop Color="#120C08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="#0A0704" CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <Button Content="←" Style="{StaticResource ExitButtonStyle}"
                            FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Click="BackButton_Click"/>
                    <TextBlock Text="✦  ASSIGNACIÓ D'HABILITATS  ✦"
                               Foreground="{StaticResource GoldDimBrush}"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══ CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT PANEL: Character list ─── -->
                <Border Background="#0A0704" BorderBrush="#2A1A08"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="12,14,12,14">

                        <TextBlock Text="✦  PERSONATGES" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,10"/>

                        <!-- Search -->
                        <TextBox x:Name="CharSearchInput"
                                 Style="{StaticResource DarkInput}"
                                 Height="28" FontSize="11"
                                 TextChanged="CharSearch_Changed"/>

                        <ScrollViewer Margin="0,8,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="740">
                            <ListBox x:Name="CharacterList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     SelectionChanged="CharacterList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding"    Value="0"/>
                                        <Setter Property="Margin"     Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            Background="#110D07"
                                                            BorderBrush="#2A1A08"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Padding="10,8">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1F1208"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#8A6015"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#160F07"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Thumb -->
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="2"
                                                    BorderBrush="#3D2210" BorderThickness="1"
                                                    Background="#0A0704">
                                                <Image Source="{Binding ThumbSource}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#D4C5A9"
                                                           FontFamily="Georgia" FontSize="12"/>
                                                <TextBlock Text="{Binding LevelDisplay}"
                                                           Style="{StaticResource SmallMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ─── RIGHT PANEL: Character detail + skill assignment ─── -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <!-- Empty state -->
                    <Grid>
                        <Border x:Name="NoSelectionPanel"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="☽ ✦ ☾"
                                           Foreground="#2D1E10"
                                           FontSize="28" HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="Selecciona un personatge de la llista"
                                           Foreground="#2D1E10"
                                           FontFamily="Georgia" FontSize="13"
                                           FontStyle="Italic" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Character detail panel (hidden until selection) -->
                        <StackPanel x:Name="CharDetailPanel"
                                    Visibility="Collapsed"
                                    Margin="18,14,18,14">

                            <!-- ─── Character card ─── -->
                            <Border Style="{StaticResource SectionPanel}" Margin="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="85"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumb image -->
                                    <Border Grid.Column="0" Width="90" Height="90"
                                            BorderBrush="#5C3A1E" BorderThickness="1"
                                            CornerRadius="4" Background="#0A0704">
                                        <Image x:Name="DetailThumb" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Name / Level / Description -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailName"
                                                   Foreground="#C8922A"
                                                   FontFamily="Georgia" FontSize="20"
                                                   FontWeight="Bold">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#C8922A" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock x:Name="DetailLevel"
                                                   Foreground="#8A6015"
                                                   FontFamily="Georgia" FontSize="11"
                                                   Margin="0,2,0,6"/>
                                        <TextBlock x:Name="DetailDesc"
                                                   Foreground="#7A6A5A"
                                                   FontFamily="Georgia" FontSize="11"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Full image -->
                                    <Border Grid.Column="4" Width="85" Height="90"
                                            BorderBrush="#3D2210" BorderThickness="1"
                                            CornerRadius="4" Background="#0A0704">
                                        <Image x:Name="DetailFull" Stretch="UniformToFill"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ─── Stats (read-only) ─── -->
                            <Border Style="{StaticResource SectionPanel}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                        <TextBlock Grid.Column="1" Text="  ✦  STATS  ✦  "
                                                   Style="{StaticResource SectionHeader}"
                                                   VerticalAlignment="Center" Margin="0"/>
                                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                    </Grid>

                                    <WrapPanel>
                                        <!-- HP -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="HP " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatHp" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Energy -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Energy " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatEnergy" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Attack -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ATK " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatAtk" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Defense -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="DEF " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatDef" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Speed -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="SPD " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatSpd" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Crit Chance -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Crit% " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatCrit" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Crit Damage -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="CritDmg " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatCritDmg" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Accuracy -->
                                        <Border Background="#0D0904" BorderBrush="#2A1A08"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="10,6" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Acc× " Style="{StaticResource StatName}"/>
                                                <TextBlock x:Name="StatAcc" Style="{StaticResource StatReadOnly}"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- ─── Assigned skills ─── -->
                            <Border Style="{StaticResource SectionPanel}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                        <TextBlock Grid.Column="1" Text="  ✦  HABILITATS DEL PERSONATGE  ✦  "
                                                   Style="{StaticResource SectionHeader}"
                                                   VerticalAlignment="Center" Margin="0"/>
                                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                    </Grid>

                                    <ItemsControl x:Name="AssignedSkillsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0D0904" BorderBrush="#3D2210"
                                                        BorderThickness="1" CornerRadius="4"
                                                        Margin="0,0,0,6" Padding="10,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#C8922A" FontFamily="Georgia"
                                                                           FontSize="12" FontWeight="Bold"
                                                                           Margin="0,0,10,0"/>
                                                                <Border Background="#1A0A04" BorderBrush="#5C3A1E"
                                                                        BorderThickness="1" CornerRadius="2" Padding="4,1"
                                                                        Margin="0,0,4,0">
                                                                    <TextBlock Text="{Binding TargetType}"
                                                                               Foreground="#7A6A5A" FontFamily="Georgia" FontSize="9"/>
                                                                </Border>
                                                                <Border Background="#1A0A04" BorderBrush="#5C3A1E"
                                                                        BorderThickness="1" CornerRadius="2" Padding="4,1"
                                                                        Visibility="{Binding AoeBadgeVisibility}">
                                                                    <TextBlock Text="AOE" Foreground="#8B1A1A"
                                                                               FontFamily="Georgia" FontSize="9"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Cost: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding EnergyCostDisplay}"
                                                                           Foreground="#D4C5A9" FontFamily="Georgia"
                                                                           FontSize="10" Margin="0,0,12,0"/>
                                                                <TextBlock Text="Acc: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding AccuracyDisplay}"
                                                                           Foreground="#D4C5A9" FontFamily="Georgia"
                                                                           FontSize="10" Margin="0,0,12,0"/>
                                                                <TextBlock Text="Hits: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding Hits}"
                                                                           Foreground="#D4C5A9" FontFamily="Georgia" FontSize="10"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding EffectsSummary}"
                                                                       Foreground="#5C3A1E" FontFamily="Georgia" FontSize="10"
                                                                       TextWrapping="Wrap" Margin="0,3,0,0"
                                                                       Visibility="{Binding EffectsVisibility}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Style="{StaticResource RemoveBtnStyle}"
                                                                Tag="{Binding}" VerticalAlignment="Top"
                                                                Click="RemoveSkill_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border x:Name="NoSkillsPlaceholder"
                                            BorderBrush="#1E1208" BorderThickness="1"
                                            CornerRadius="3" Padding="14,16">
                                        <TextBlock Text="Cap habilitat assignada."
                                                   Foreground="#2D1E10" FontFamily="Georgia" FontSize="11"
                                                   FontStyle="Italic" TextAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ─── Skills to choose ─── -->
                            <Border Style="{StaticResource SectionPanel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="175"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                                       Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                            <TextBlock Grid.Column="1" Text="  ✦  AFEGIR HABILITATS  ✦  "
                                                       Style="{StaticResource SectionHeader}"
                                                       VerticalAlignment="Center" Margin="0"/>
                                            <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                                       Fill="{StaticResource GoldDimBrush}" Opacity="0.4"/>
                                        </Grid>

                                        <Button Content="⊕  Afegir seleccionada"
                                                Style="{StaticResource AddSkillBtnStyle}"
                                                Width="180" HorizontalAlignment="Left"
                                                Margin="0,0,0,10"
                                                Click="AddSelectedSkill_Click"/>

                                        <ListBox x:Name="AvailableSkillsList"
                                                 Background="Transparent"
                                                 BorderBrush="#2A1A08" BorderThickness="1"
                                                 MaxHeight="280"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Background"  Value="Transparent"/>
                                                    <Setter Property="Padding"     Value="0"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#1F1208"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#160F07"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#1E1208" BorderThickness="0,0,0,1" Padding="10,8">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#C8922A" FontFamily="Georgia"
                                                                           FontSize="12" FontWeight="Bold" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding TargetType}"
                                                                           Foreground="#5C3A1E" FontFamily="Georgia"
                                                                           FontSize="10" VerticalAlignment="Center"/>
                                                                <TextBlock Text="  AOE" Foreground="#8B1A1A"
                                                                           FontFamily="Georgia" FontSize="10"
                                                                           Visibility="{Binding AoeBadgeVisibility}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Cost: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding EnergyCostDisplay}"
                                                                           Foreground="#D4C5A9" FontFamily="Georgia"
                                                                           FontSize="10" Margin="0,0,10,0"/>
                                                                <TextBlock Text="Acc: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding AccuracyDisplay}"
                                                                           Foreground="#D4C5A9" FontFamily="Georgia" FontSize="10"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding EffectsSummary}"
                                                                       Foreground="#5C3A1E" FontFamily="Georgia" FontSize="10"
                                                                       TextWrapping="Wrap"
                                                                       Visibility="{Binding EffectsVisibility}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <!-- Filters -->
                                    <Border Grid.Column="2" Background="#0D0904"
                                            BorderBrush="#2A1A08" BorderThickness="1"
                                            CornerRadius="4" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="FILTRES:" Foreground="#C8922A"
                                                       FontFamily="Georgia" FontSize="11" FontWeight="Bold"
                                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Cerca per nom:" Style="{StaticResource FilterLabel}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="FilterNameInput" Style="{StaticResource DarkInput}"
                                                     Height="28" FontSize="11" TextChanged="Filter_Changed"/>
                                            <TextBlock Text="Energia màx:" Style="{StaticResource FilterLabel}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock x:Name="EnergyCostFilterVal" Text="Any"
                                                           Foreground="#C8922A" FontFamily="Georgia" FontSize="11"
                                                           Width="30" VerticalAlignment="Center"/>
                                                <Slider x:Name="EnergyCostFilter" Minimum="0" Maximum="100" Value="100"
                                                        Width="100" Style="{StaticResource GoldSlider}"
                                                        ValueChanged="FilterSlider_Changed"/>
                                            </StackPanel>
                                            <TextBlock Text="Precisió mín:" Style="{StaticResource FilterLabel}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock x:Name="AccuracyFilterVal" Text="0%"
                                                           Foreground="#C8922A" FontFamily="Georgia" FontSize="11"
                                                           Width="30" VerticalAlignment="Center"/>
                                                <Slider x:Name="AccuracyFilter" Minimum="0" Maximum="100" Value="0"
                                                        Width="100" Style="{StaticResource GoldSlider}"
                                                        ValueChanged="FilterSlider_Changed"/>
                                            </StackPanel>
                                            <TextBlock Text="Tipus:" Style="{StaticResource FilterLabel}"/>
                                            <WrapPanel>
                                                <CheckBox x:Name="FilterSingle" Content="Single"
                                                          Style="{StaticResource FilterCheck}"
                                                          Checked="Filter_CheckChanged" Unchecked="Filter_CheckChanged"/>
                                                <CheckBox x:Name="FilterAoe" Content="AoE"
                                                          Style="{StaticResource FilterCheck}"
                                                          Checked="Filter_CheckChanged" Unchecked="Filter_CheckChanged"/>
                                                <CheckBox x:Name="FilterPassive" Content="Passive"
                                                          Style="{StaticResource FilterCheck}"
                                                          Checked="Filter_CheckChanged" Unchecked="Filter_CheckChanged"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" Background="#0A0704" CornerRadius="0,0,6,6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="22,0">
                    <TextBlock x:Name="FooterHint"
                               Text="Selecciona un personatge per gestionar les seves habilitats"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Georgia" FontSize="10"
                               VerticalAlignment="Center" Opacity="0.5"/>
                    <Button Content="  ✦  GUARDAR CANVIS  ✦  "
                            Style="{StaticResource ActionButtonStyle}"
                            HorizontalAlignment="Right" Width="200" Height="36"
                            Click="SaveAssignment_Click"
                            x:Name="SaveBtn" IsEnabled="False">
                        <Button.Foreground>
                            <SolidColorBrush Color="#C8922A"/>
                        </Button.Foreground>
                        <Button.FontSize>13</Button.FontSize>
                        <Button.FontFamily>Georgia</Button.FontFamily>
                        <Button.Effect>
                            <DropShadowEffect Color="#C8922A" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
