<Window x:Class="LightestDungeonCreator.CreadorHabilitat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Creador Habilitat"
        Height="720" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D2210">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0A08" Offset="0"/>
                <GradientStop Color="#120C08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0" Background="#0A0704" CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="✦  LIGHTEST DUNGEON  —  CREAR HABILITAT"
                               Foreground="{StaticResource GoldDimBrush}"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Button Content="✕"
                            Style="{StaticResource ExitButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,24,40,24">

                    <!-- Top ornament + title -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                        <TextBlock Grid.Column="1" Text="  ✦  "
                                   Foreground="{StaticResource GoldDimBrush}"
                                   FontSize="16" Margin="10,0"/>
                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                    </Grid>

                    <TextBlock Text="DISSENYA UN PODER"
                               Foreground="{StaticResource GoldBrush}"
                               FontFamily="Georgia" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#C8922A" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Defineix els paràmetres de l'habilitat i els seus efectes."
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Georgia" FontSize="11" FontStyle="Italic"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <!-- ══════════════════════════════════════════
                         SECTION 1 — IDENTITAT
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="IDENTITAT" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Nom -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="NOM DE L'HABILITAT" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtNom"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         MaxLength="50"
                                         ToolTip="Màxim 50 caràcters"/>
                            </StackPanel>

                            <!-- Imatge miniatura -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="RUTA IMATGE MINIATURA" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtImageThumb"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" MaxLength="500"/>
                                    <Button Grid.Column="1" Content="..."
                                            Style="{StaticResource SecondarySmallButtonStyle}"
                                            Margin="6,0,0,0" Width="36"
                                            Click="BtnBrowseThumb_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- Descripció -->
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1">
                                <TextBlock Text="DESCRIPCIÓ" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtDescripcio"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Height="58" TextWrapping="Wrap"
                                         AcceptsReturn="True" MaxLength="500"
                                         ToolTip="Màxim 500 caràcters"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         SECTION 2 — MECÀNICA
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="MECÀNICA" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Cost d'energia -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="COST D'ENERGIA" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtEnergyCost"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="0"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Precisió -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    PRECISIÓ
                                    <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (0.0 – 1.0)"/>
                                </TextBlock>
                                <TextBox x:Name="TxtAccuracy"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="1.0"
                                         PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Impactes (hits) -->
                            <StackPanel Grid.Column="4" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="NOMBRE D'IMPACTES" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtHits"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="1"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Tipus de target -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Text="TIPUS D'OBJECTIU" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="CmbTargetType"
                                          Style="{StaticResource DarkComboBoxStyle}">
                                    <ComboBoxItem Content="Single"   IsSelected="True"/>
                                    <ComboBoxItem Content="Self"/>
                                    <ComboBoxItem Content="Ally"/>
                                    <ComboBoxItem Content="AllAllies"/>
                                    <ComboBoxItem Content="Enemy"/>
                                    <ComboBoxItem Content="AllEnemies"/>
                                    <ComboBoxItem Content="All"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- AoE -->
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,14"
                                        VerticalAlignment="Center">
                                <TextBlock Text="ÀREA D'EFECTE (AoE)" Style="{StaticResource FieldLabelStyle}"/>
                                <CheckBox x:Name="ChkIsAoe"
                                          FontFamily="Georgia" FontSize="13"
                                          Content="Afecta múltiples objectius"
                                          Margin="0,6,0,0"
                                          Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>

                            <!-- Passiva -->
                            <StackPanel Grid.Column="4" Grid.Row="1" Margin="0,0,0,14"
                                        VerticalAlignment="Center">
                                <TextBlock Text="TIPUS D'ACTIVACIÓ" Style="{StaticResource FieldLabelStyle}"/>
                                <CheckBox x:Name="ChkIsPassive"
                                          FontFamily="Georgia" FontSize="13"
                                          Content="Habilitat passiva"
                                          Margin="0,6,0,0"
                                          Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         SECTION 3 — EFECTES
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="EFECTES" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Afegeix els efectes que aplica aquesta habilitat en activar-se."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Georgia" FontSize="11" FontStyle="Italic"
                                       Margin="0,0,0,12"/>

                            <!-- List of added effects -->
                            <Border Background="#120C06"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="2"
                                    MinHeight="60" Margin="0,0,0,12">
                                <StackPanel x:Name="PanelEffectsList" Margin="8">
                                    <TextBlock x:Name="TxtNoEffects"
                                               Text="Cap efecte afegit."
                                               Foreground="{StaticResource MutedBrush}"
                                               FontFamily="Georgia" FontSize="11"
                                               FontStyle="Italic" HorizontalAlignment="Center"
                                               Margin="0,16"/>
                                </StackPanel>
                            </Border>

                            <!-- Add effect form -->
                            <Border Background="#1A1209"
                                    BorderBrush="{StaticResource GoldDimBrush}"
                                    BorderThickness="1" CornerRadius="2"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Fila 0 - Min Power, Max Power, Multiplier, Probability -->
                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="PODER MÍNIM" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="TxtEffMinPower"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="0"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="PODER MÀXIM" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="TxtEffMaxPower"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="0"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                                            MULTIPLICADOR
                                            <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (stat)"/>
                                        </TextBlock>
                                        <TextBox x:Name="TxtEffMultiplier"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="1.0"
                                                 PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                                            PROBABILITAT
                                            <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (0-1)"/>
                                        </TextBlock>
                                        <TextBox x:Name="TxtEffProbability"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="1.0"
                                                 PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <!-- Fila 1 - Durada, Nivell efecte, Stat ID, Status ID -->
                                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Text="DURADA (torns)" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="TxtEffDuration"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="1"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Text="NIVELL EFECTE" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="TxtEffLevel"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Text="1"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                                            STAT ID
                                            <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (opcional)"/>
                                        </TextBlock>
                                        <TextBox x:Name="TxtEffStatId"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 ToolTip="ID de l'estadística afectada. Deixa buit si és un Status."
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6" Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                                            STATUS ID
                                            <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (opcional)"/>
                                        </TextBlock>
                                        <TextBox x:Name="TxtEffStatusId"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 ToolTip="ID de l'estat alterat. Deixa buit si és un Stat."
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                    </StackPanel>

                                    <!-- Botó afegir efecte -->
                                    <Button Grid.Column="0" Grid.ColumnSpan="7" Grid.Row="2"
                                            Content="＋  AFEGIR EFECTE"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Height="32"
                                            HorizontalAlignment="Right"
                                            Width="180"
                                            Click="BtnAfegirEfecte_Click"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Bottom ornament -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                        <TextBlock Grid.Column="1" Text="  ✦  "
                                   Foreground="{StaticResource GoldDimBrush}"
                                   FontSize="10" Margin="6,0" Opacity="0.5"/>
                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer action bar ── -->
            <Border Grid.Row="2"
                    Background="#0A0704"
                    CornerRadius="0,0,6,6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="40,0">
                    <TextBlock x:Name="TxtValidation"
                               Foreground="#CC3333"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="CANCEL·LAR"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Width="120" Height="32"
                                Margin="0,0,12,0"
                                Click="BtnCancel_Click"/>
                        <Button Content="✦  GUARDAR HABILITAT"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="200" Height="32"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
