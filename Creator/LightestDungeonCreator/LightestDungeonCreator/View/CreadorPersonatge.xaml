<Window x:Class="LightestDungeonCreator.CreadorPersonatge"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CreadorPersonatge"
        Height="720" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer container matching SplashScreen style -->
    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D2210">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0A08" Offset="0"/>
                <GradientStop Color="#120C08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="52"/>   <!-- Footer actions -->
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0" Background="#0A0704" CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="✦  DARKEST DUNGEON  —  CREAR PERSONATGE"
                               Foreground="{StaticResource GoldDimBrush}"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Button Content="✕"
                            Style="{StaticResource ExitButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="0" Padding="0">
                <StackPanel Margin="40,24,40,24">

                    <!-- Top ornament + title -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                        <TextBlock Grid.Column="1" Text="  ⚔  "
                                   Foreground="{StaticResource GoldDimBrush}"
                                   FontSize="16" Margin="10,0"/>
                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                    </Grid>

                    <TextBlock Text="FORJA UN NOU GUERRER"
                               Foreground="{StaticResource GoldBrush}"
                               FontFamily="Georgia" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#C8922A" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Omple els atributs per definir el teu heroi a la foscor."
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Georgia" FontSize="11" FontStyle="Italic"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <!-- ══════════════════════════════════════════
                         SECTION 1 — IDENTITAT
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="IDENTITAT"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Nom -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="NOM DEL PERSONATGE"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtNom"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         MaxLength="50"
                                         ToolTip="Màxim 50 caràcters"/>
                            </StackPanel>

                            <!-- Nivell -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="NIVELL" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderNivell"
                                            Style="{StaticResource DarkSliderStyle}"
                                            Minimum="1" Maximum="20" Value="1"
                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                            VerticalAlignment="Center"
                                            ValueChanged="SliderNivell_ValueChanged"/>
                                    <TextBox x:Name="TxtNivell" Grid.Column="1"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Text="1" TextAlignment="Center"
                                             Margin="8,0,0,0"
                                             PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </Grid>
                            </StackPanel>

                            <!-- Tipus (Player / Enemy) -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Text="TIPUS" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="CmbTipus"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectionChanged="CmbTipus_SelectionChanged">
                                    <ComboBoxItem Content="Jugador (Player)" Tag="Player" IsSelected="True"/>
                                    <ComboBoxItem Content="Enemic (Enemy)"   Tag="Enemy"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Descripció -->
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Text="DESCRIPCIÓ" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtDescripcio"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Height="58" TextWrapping="Wrap"
                                         AcceptsReturn="True" MaxLength="500"
                                         ToolTip="Màxim 500 caràcters"/>
                            </StackPanel>

                            <!-- Separator line -->
                            <Rectangle Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                       Height="1" Fill="{StaticResource BorderBrush}"
                                       Opacity="0.4" Margin="0,4,0,14"/>

                            <!-- Imatge miniatura -->
                            <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,0,0">
                                <TextBlock Text="RUTA IMATGE MINIATURA" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtImageThumb"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" MaxLength="500"/>
                                    <Button Grid.Column="1" Content="..."
                                            Style="{StaticResource SecondarySmallButtonStyle}"
                                            Margin="6,0,0,0" Width="36"
                                            Click="BtnBrowseThumb_Click"
                                            ToolTip="Selecciona imatge miniatura"/>
                                </Grid>
                            </StackPanel>

                            <!-- Imatge completa -->
                            <StackPanel Grid.Column="2" Grid.Row="3" Margin="0,0,0,0">
                                <TextBlock Text="RUTA IMATGE COMPLETA" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtImageFull"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" MaxLength="500"/>
                                    <Button Grid.Column="1" Content="..."
                                            Style="{StaticResource SecondarySmallButtonStyle}"
                                            Margin="6,0,0,0" Width="36"
                                            Click="BtnBrowseFull_Click"
                                            ToolTip="Selecciona imatge completa"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         SECTION 2 — VIDA I ENERGIA
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="VIDA I ENERGIA"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- HP -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="HP ACTUAL" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtHp"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="100"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- HP Max -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="HP MÀXIM" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtHpMax"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="100"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Energy -->
                            <StackPanel Grid.Column="0" Grid.Row="1">
                                <TextBlock Text="ENERGIA ACTUAL" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtEnergy"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="100"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Energy Max -->
                            <StackPanel Grid.Column="2" Grid.Row="1">
                                <TextBlock Text="ENERGIA MÀXIMA" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtEnergyMax"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="100"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         SECTION 3 — ESTADÍSTIQUES DE COMBAT
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="ESTADÍSTIQUES DE COMBAT"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Attack -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="ATAC" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtAttack"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="10"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Defense -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="DEFENSA" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtDefense"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="5"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Speed -->
                            <StackPanel Grid.Column="4" Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="VELOCITAT" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtSpeed"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="5"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Crit Chance -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    PROBABILITAT CRÍTICA
                                    <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (0.0 – 1.0)"/>
                                </TextBlock>
                                <TextBox x:Name="TxtCritChance"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="0.05"
                                         PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Crit Damage -->
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    DANY CRÍTIC
                                    <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (multiplicador)"/>
                                </TextBlock>
                                <TextBox x:Name="TxtCritDamage"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="1.5"
                                         PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                            </StackPanel>

                            <!-- Accuracy -->
                            <StackPanel Grid.Column="4" Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    PRECISIÓ
                                    <Run Foreground="{StaticResource MutedBrush}" FontStyle="Italic" Text=" (multiplicador)"/>
                                </TextBlock>
                                <TextBox x:Name="TxtAccuracy"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="1.0"
                                         PreviewTextInput="DecimalOnly_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         SECTION 4 — ESPECÍFIC JUGADOR
                         (visible only when Tipus = Player)
                    ══════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelPlayer">
                        <TextBlock Text="ATRIBUTS DE JUGADOR"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- XP Points -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PUNTS D'EXPERIÈNCIA (XP)"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TxtXpPoints"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Text="0"
                                             PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </StackPanel>

                                <!-- Skill Points -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="PUNTS D'HABILITAT"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="TxtSkillPoints"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Text="0"
                                             PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════════════════════════════════
                         SECTION 5 — ESPECÍFIC ENEMIC
                         (visible only when Tipus = Enemy)
                    ══════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelEnemy" Visibility="Collapsed">
                        <TextBlock Text="ATRIBUTS D'ENEMIC"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="HABILITAT PASSIVA (ID)"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtPassiveId"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         Text="0"
                                         ToolTip="ID de la habilitat passiva assignada a l'enemic"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                <TextBlock Text="La taula de botí es crearà automàticament en guardar."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="Georgia" FontSize="10"
                                           FontStyle="Italic" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Bottom ornament -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                        <TextBlock Grid.Column="1" Text="  ✦  "
                                   Foreground="{StaticResource GoldDimBrush}"
                                   FontSize="10" Margin="6,0" Opacity="0.5"/>
                        <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                   Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer action bar ── -->
            <Border Grid.Row="2"
                    Background="#0A0704"
                    CornerRadius="0,0,6,6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="40,0">
                    <!-- Validation message -->
                    <TextBlock x:Name="TxtValidation"
                               Foreground="#CC3333"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Visibility="Collapsed"/>
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="CANCEL·LAR"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Width="120" Height="32"
                                Margin="0,0,12,0"
                                Click="BtnCancel_Click"/>
                        <Button Content="✦  GUARDAR PERSONATGE"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="200" Height="32"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
