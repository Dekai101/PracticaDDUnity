<Window x:Class="LightestDungeonCreator.EnemyListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enemy List"
        Height="700" Width="900"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#120C06"/>
            <Setter Property="Foreground"      Value="#D4C5A9"/>
            <Setter Property="BorderBrush"     Value="#5C3A1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontFamily"      Value="Georgia"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8922A"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#8B1A1A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SmallMuted" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5C3A1E"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,6,0,2"/>
        </Style>

        <!-- Red slider (enemy theme) -->
        <Style x:Key="RedSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#8B1A1A" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#2A1A08" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="20" CornerRadius="2"
                                                        Background="#8B1A1A" BorderBrush="#5C1010" BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#8B1A1A" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Enemy list item -->
        <Style x:Key="EnemyItemBorder" TargetType="Border">
            <Setter Property="Background"      Value="#0E0604"/>
            <Setter Property="BorderBrush"     Value="#1E0808"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A0808"/>
                    <Setter Property="BorderBrush" Value="#5C1010"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stat chip - red version -->
        <Style x:Key="StatChipRed" TargetType="Border">
            <Setter Property="Background"      Value="#140808"/>
            <Setter Property="BorderBrush"     Value="#3D1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Margin"          Value="0,0,6,6"/>
        </Style>

        <!-- Detail label -->
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,8,0,4"/>
        </Style>

        <!-- Detail value -->
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#D4C5A9"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>

        <!-- Stat bar container -->
        <Style x:Key="StatBarBg" TargetType="Border">
            <Setter Property="Background"      Value="#1A0808"/>
            <Setter Property="BorderBrush"     Value="#3D1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Height"          Value="6"/>
            <Setter Property="Margin"          Value="0,3,0,8"/>
        </Style>

        <!-- Delete button -->
        <Style x:Key="DeleteBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1A0808"/>
            <Setter Property="BorderBrush"     Value="#5C1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#8B1A1A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Georgia"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="10,5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#2A0808"/>
                                <Setter TargetName="R" Property="BorderBrush" Value="#8B1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D1010">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0806" Offset="0"/>
                <GradientStop Color="#120804" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ══════════════ TITLE BAR ══════════════ -->
            <Border Grid.Row="0" Background="#0A0404" CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <Button Content="←"
                            Style="{StaticResource ExitButtonStyle}"
                            FontSize="18"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Click="BackButton_Click"/>
                    <TextBlock Text="☠  ENEMY REGISTRY  ☠"
                               Foreground="#5C1010"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ══════════════ CONTENT ══════════════ -->
            <Grid Grid.Row="1" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ────────────── LEFT COLUMN ────────────── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Border Grid.Row="0"
                            Background="#0D0404" BorderBrush="#3D1010"
                            BorderThickness="1" CornerRadius="4"
                            Padding="12,10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="FILTERS" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>

                            <TextBlock Text="SEARCH BY NAME" Style="{StaticResource FilterLabel}" Margin="0,0,0,3"/>
                            <TextBox x:Name="FilterNameInput"
                                     Style="{StaticResource DarkInput}"
                                     Height="28" FontSize="11"
                                     TextChanged="FilterName_Changed"/>

                            <!-- Min level slider -->
                            <TextBlock Text="MIN LEVEL" Style="{StaticResource FilterLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="MinLevelVal"
                                           Text="Any"
                                           Foreground="#8B1A1A" FontFamily="Georgia" FontSize="11"
                                           Width="28" VerticalAlignment="Center"/>
                                <Slider x:Name="MinLevelFilter"
                                        Style="{StaticResource RedSlider}"
                                        Minimum="1" Maximum="100" Value="1"
                                        Width="220"
                                        ValueChanged="FilterLevelSlider_Changed"/>
                            </StackPanel>

                            <!-- Min HP slider -->
                            <TextBlock Text="MIN HP" Style="{StaticResource FilterLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock x:Name="MinHpVal"
                                           Text="Any"
                                           Foreground="#8B1A1A" FontFamily="Georgia" FontSize="11"
                                           Width="28" VerticalAlignment="Center"/>
                                <Slider x:Name="MinHpFilter"
                                        Style="{StaticResource RedSlider}"
                                        Minimum="0" Maximum="1000" Value="0"
                                        Width="220"
                                        ValueChanged="FilterHpSlider_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Enemy list -->
                    <Border Grid.Row="1"
                            Background="#0A0404" BorderBrush="#3D1010"
                            BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#0D0404" CornerRadius="4,4,0,0"
                                    BorderBrush="#2A0808" BorderThickness="0,0,0,1"
                                    Padding="12,7">
                                <Grid>
                                    <TextBlock Foreground="#8B1A1A" FontFamily="Georgia"
                                               FontSize="10" FontWeight="Bold"
                                               Text="ENEMIES"/>
                                    <TextBlock x:Name="EnemyCountLabel"
                                               Foreground="#3D1010" FontFamily="Georgia"
                                               FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="NoEnemiesLabel"
                                       Grid.Row="1"
                                       Text="No enemies found."
                                       Foreground="#3D1010" FontFamily="Georgia"
                                       FontSize="11" FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="EnemyList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource EnemyItemBorder}"
                                                    MouseLeftButtonDown="EnemyItem_Click"
                                                    Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Thumbnail -->
                                                    <Border Grid.Column="0"
                                                            Width="40" Height="40"
                                                            BorderBrush="#3D1010"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Background="#0A0404">
                                                        <Image Source="{Binding Entity.ImageThumb}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>

                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Entity.Name}"
                                                                   Foreground="#D4C5A9"
                                                                   FontFamily="Georgia"
                                                                   FontSize="12" FontWeight="Bold"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="Lv." Style="{StaticResource SmallMuted}"/>
                                                            <TextBlock Text="{Binding Entity.Level}"
                                                                       Foreground="#8B1A1A" FontFamily="Georgia"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Margin="2,0,10,0"/>
                                                            <TextBlock Text="HP: " Style="{StaticResource SmallMuted}"/>
                                                            <TextBlock Text="{Binding Entity.HpMax}"
                                                                       Foreground="#D4C5A9" FontFamily="Georgia"
                                                                       FontSize="10" Margin="0,0,10,0"/>
                                                            <TextBlock Text="ATK: " Style="{StaticResource SmallMuted}"/>
                                                            <TextBlock Text="{Binding Entity.Attack}"
                                                                       Foreground="#D4C5A9" FontFamily="Georgia"
                                                                       FontSize="10"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ────────────── RIGHT COLUMN: DETAIL ────────────── -->
                <Border Grid.Column="2"
                        Background="#0A0404" BorderBrush="#3D1010"
                        BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <!-- Empty state -->
                        <StackPanel x:Name="DetailEmpty"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="☠"
                                       Foreground="#1A0808" FontFamily="Georgia"
                                       FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select an enemy to view details"
                                       Foreground="#2A1010" FontFamily="Georgia"
                                       FontSize="12" FontStyle="Italic"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Detail content -->
                        <ScrollViewer x:Name="DetailPanel"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed"
                                      Padding="18,16">
                            <StackPanel>

                                <!-- Image + name -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="76" Height="76"
                                            BorderBrush="#3D1010" BorderThickness="1"
                                            CornerRadius="4" Background="#0A0404">
                                        <Image x:Name="DetailImage" Stretch="UniformToFill" Margin="2"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailName"
                                                   Foreground="#8B1A1A"
                                                   FontFamily="Georgia"
                                                   FontSize="20" FontWeight="Bold">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#8B1A1A" BlurRadius="8"
                                                                  ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="LEVEL  "
                                                       Foreground="#3D1010" FontFamily="Georgia" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock x:Name="DetailLevel"
                                                       Foreground="#8B1A1A" FontFamily="Georgia"
                                                       FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock x:Name="DetailId"
                                                   Foreground="#2A1010" FontFamily="Georgia"
                                                   FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="#2A0808" Margin="0,0,0,12"/>

                                <!-- Description -->
                                <TextBlock Text="DESCRIPTION" Style="{StaticResource DetailLabel}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="DetailDescription"
                                           Foreground="#5C3A1E" FontFamily="Georgia"
                                           FontSize="11" FontStyle="Italic"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <!-- Combat stats -->
                                <TextBlock Text="COMBAT STATS" Style="{StaticResource DetailLabel}"/>
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- HP -->
                                    <StackPanel Grid.Column="0" Grid.Row="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="HP  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailHp"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource StatBarBg}">
                                            <Border x:Name="BarHp" Background="#8B1A1A"
                                                    CornerRadius="2" HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Energy -->
                                    <StackPanel Grid.Column="2" Grid.Row="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ENERGY  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailEnergy"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource StatBarBg}">
                                            <Border x:Name="BarEnergy" Background="#1A4A8B"
                                                    CornerRadius="2" HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Attack -->
                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ATK  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailAttack"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource StatBarBg}">
                                            <Border x:Name="BarAttack" Background="#8B4A1A"
                                                    CornerRadius="2" HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Defense -->
                                    <StackPanel Grid.Column="2" Grid.Row="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="DEF  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailDefense"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                        <Border Style="{StaticResource StatBarBg}">
                                            <Border x:Name="BarDefense" Background="#1A5C1A"
                                                    CornerRadius="2" HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Speed -->
                                    <StackPanel Grid.Column="0" Grid.Row="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SPD  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailSpeed"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Crit -->
                                    <StackPanel Grid.Column="2" Grid.Row="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="CRIT  " Style="{StaticResource SmallMuted}"/>
                                            <TextBlock x:Name="DetailCrit"
                                                       Foreground="#D4C5A9" FontFamily="Georgia" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Assigned skills -->
                                <TextBlock Text="SKILLS" Style="{StaticResource DetailLabel}"/>
                                <Border Background="#0D0404" BorderBrush="#2A0808"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="10,8" Margin="0,4,0,12">
                                    <ItemsControl x:Name="DetailSkillsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#140808" BorderBrush="#2A0808"
                                                        BorderThickness="1" CornerRadius="2"
                                                        Padding="8,6" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="26" Height="26"
                                                                BorderBrush="#3D1010" BorderThickness="1"
                                                                CornerRadius="2" Background="#0A0404">
                                                            <Image Source="{Binding ImageThumb}"
                                                                   Stretch="UniformToFill"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#D4C5A9"
                                                                           FontFamily="Georgia"
                                                                           FontSize="11" FontWeight="Bold"/>
                                                                <TextBlock Text="   PASSIVE"
                                                                           Foreground="#5C1010"
                                                                           FontFamily="Georgia" FontSize="9"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPassive}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Cost: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding EnergyCost}"
                                                                           Foreground="#D4C5A9"
                                                                           FontFamily="Georgia" FontSize="10"
                                                                           Margin="0,0,8,0"/>
                                                                <TextBlock Text="Acc: " Style="{StaticResource SmallMuted}"/>
                                                                <TextBlock Text="{Binding Accuracy, StringFormat={}{0:P0}}"
                                                                           Foreground="#D4C5A9"
                                                                           FontFamily="Georgia" FontSize="10"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Full image preview -->
                                <TextBlock Text="FULL IMAGE" Style="{StaticResource DetailLabel}"/>
                                <Border BorderBrush="#3D1010" BorderThickness="1"
                                        CornerRadius="3" Background="#0A0404"
                                        MaxHeight="180" Margin="0,4,0,12">
                                    <Image x:Name="DetailFullImage"
                                           Stretch="Uniform" Margin="4"
                                           MaxHeight="172"/>
                                </Border>

                                <!-- Delete -->
                                <Button x:Name="DeleteEnemyBtn"
                                        Content="☠  DELETE ENEMY"
                                        Style="{StaticResource DeleteBtnStyle}"
                                        HorizontalAlignment="Right"
                                        Width="150" Height="32"
                                        Click="DeleteEnemy_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════ FOOTER ══════════════ -->
            <Border Grid.Row="2"
                    Background="#0A0404" CornerRadius="0,0,6,6"
                    BorderBrush="#3D1010" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <TextBlock x:Name="FooterLabel"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Georgia" FontSize="10"
                               VerticalAlignment="Center" Opacity="0.5"/>
                    <Button Content="＋  NEW ENEMY"
                            Style="{StaticResource ActionButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="150" Height="28"
                            Click="NewEnemy_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#8B1A1A"/>
                        </Button.Foreground>
                        <Button.FontSize>11</Button.FontSize>
                        <Button.FontFamily>Georgia</Button.FontFamily>
                        <Button.Effect>
                            <DropShadowEffect Color="#8B1A1A" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
