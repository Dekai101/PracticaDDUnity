<Window x:Class="LightestDungeonCreator.ItemCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Creator"
        Height="880" Width="780"
        MinHeight="600" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <!-- Dark TextBox -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#120C06"/>
            <Setter Property="Foreground"      Value="#D4C5A9"/>
            <Setter Property="BorderBrush"     Value="#5C3A1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontFamily"      Value="Georgia"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8922A"/>
            <Setter Property="SelectionBrush"  Value="#5C3A1E"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,6,0,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C8922A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
        </Style>

        <!-- Add button -->
        <Style x:Key="AddBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1F1208"/>
            <Setter Property="BorderBrush"     Value="#8A6015"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#C8922A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#3A2210"/>
                                <Setter TargetName="R" Property="BorderBrush" Value="#C8922A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#0F0904"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ✕ Remove button -->
        <Style x:Key="RemoveBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#5C3A1E"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="T" Text="✕"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="T" Property="Foreground" Value="#CC3333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,20,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#C8922A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#7A6A5A"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#C8922A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Table header cell -->
        <Style x:Key="TH" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#8A6015"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>

        <!-- Table data cell -->
        <Style x:Key="TD" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#D4C5A9"/>
            <Setter Property="FontFamily"  Value="Georgia"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="6,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Section panel -->
        <Style x:Key="SectionPanel" TargetType="Border">
            <Setter Property="Background"      Value="#110D07"/>
            <Setter Property="BorderBrush"     Value="#5C3A1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="Margin"          Value="0,10,0,0"/>
        </Style>

    </Window.Resources>

    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D2210">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0A08" Offset="0"/>
                <GradientStop Color="#120C08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <!-- Title bar  -->
                <RowDefinition Height="*"/>
                <!-- Content    -->
                <RowDefinition Height="52"/>
                <!-- Footer     -->
            </Grid.RowDefinitions>

            <!-- ============ TITLE BAR ============ -->
            <Border Grid.Row="0" Background="#0A0704" CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <!-- Back button -->
                    <Button Content="←"
                            Style="{StaticResource ExitButtonStyle}"
                            FontSize="18"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Click="BackButton_Click"/>
                    <!-- Title -->
                    <TextBlock Text="✦  ITEM CREATOR  ✦"
                               Foreground="{StaticResource GoldDimBrush}"
                               FontFamily="Georgia" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <!-- List icon -->
                    <Button Content="☰"
                            Style="{StaticResource ExitButtonStyle}"
                            FontSize="15"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="Ver items guardados"
                            Click="ListItems_Click"/>
                </Grid>
            </Border>

            <!-- ============ SCROLLABLE CONTENT ============ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="22,14,22,14">

                    <!-- - NAME - -->
                    <TextBlock Text="* NAME *" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                    <TextBox x:Name="NameInput"
                             Style="{StaticResource DarkInput}"
                             Height="32"
                             MaxLength="50"/>

                    <!-- - DESCRIPTION + IMAGE - -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="185"/>
                        </Grid.ColumnDefinitions>

                        <!-- Description -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="DescInput"
                                     Style="{StaticResource DarkInput}"
                                     Height="106"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="500"/>
                        </StackPanel>

                        <!-- Image -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="* IMAGE" Style="{StaticResource FieldLabel}"/>
                            <Border Width="185" Height="106"
                                    BorderBrush="#5C3A1E" BorderThickness="1"
                                    Background="#0A0704" CornerRadius="3"
                                    Cursor="Hand">
                                <Grid>
                                    <Image x:Name="ItemImagePreview"
                                           Stretch="Uniform"
                                           Margin="3"/>
                                </Grid>
                            </Border>
                            <TextBox x:Name="ImagePathInput"
                                     Style="{StaticResource DarkInput}"
                                     Height="24" FontSize="9"
                                     Margin="0,4,0,0"
                                     Foreground="#5C3A1E"
                                     TextChanged="ImagePathInput_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- =================================== -->
                    <!--         ITEM PROPERTIES             -->
                    <!-- =================================== -->
                    <Border Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="ITEM PROPERTIES" Style="{StaticResource SectionHeader}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Quality -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="*QUALITY" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="QualityCombo" Height="30"
                                          Background="#120C06" Foreground="#D4C5A9"
                                          BorderBrush="#5C3A1E"
                                          FontFamily="Georgia" FontSize="11"
                                          VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Common"    IsSelected="True"/>
                                        <ComboBoxItem Content="Uncommon"/>
                                        <ComboBoxItem Content="Rare"/>
                                        <ComboBoxItem Content="Epic"/>
                                        <ComboBoxItem Content="Legendary"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Max Uses -->
                                <StackPanel Grid.Column="2" x:Name="MaxUsesPanel">
                                    <TextBlock Text="MAX USES (only if consumable is enabled)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="MaxUsesInput"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="" IsEnabled="False"
                                         ToolTip="Leave empty for unlimited"/>
                                </StackPanel>

                                <!-- Target Type -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="*TARGET TYPE" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="ItemTargetCombo" Height="30"
                                          Background="#120C06" Foreground="#D4C5A9"
                                          BorderBrush="#5C3A1E"
                                          FontFamily="Georgia" FontSize="11"
                                      VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Enemy"     IsSelected="True"/>
                                        <ComboBoxItem Content="Ally"/>
                                        <ComboBoxItem Content="Self"/>  
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Flags -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <CheckBox x:Name="ConsumableCheck"
                                      Content="Consumable"
                                      Style="{StaticResource DarkCheck}"
                                      Margin="0,0,28,0"
                                      Checked="ConsumableCheck_Changed"
                                      Unchecked="ConsumableCheck_Changed"/>
                                <CheckBox x:Name="IsAoeCheck"
                                  Content="Is AoE"
                                  Style="{StaticResource DarkCheck}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- =================================== -->
                    <!--             STATUS SECTION          -->
                    <!-- =================================== -->
                    <Border Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="STATUS" Style="{StaticResource SectionHeader}"/>

                            <!-- Apply / Cleanse -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="StatusApplyRb"
                                             Content="Apply"
                                             GroupName="StatusMode"
                                             IsChecked="True"
                                             Style="{StaticResource DarkRadio}"/>
                                <RadioButton x:Name="StatusCleanseRb"
                                             Content="○ Cleanse"
                                             GroupName="StatusMode"
                                             Style="{StaticResource DarkRadio}"/>
                            </StackPanel>

                            <!-- Status selector + Add -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Status:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="StatusCombo"
                                          Grid.Column="1" Height="30"
                                          Background="#120C06" Foreground="#D4C5A9"
                                          BorderBrush="#5C3A1E"
                                          FontFamily="Georgia" FontSize="11"
                                          DisplayMemberPath="Name"
                                          VerticalContentAlignment="Center"/>
                                <Button Grid.Column="3" Content="⊕"
                                        Style="{StaticResource AddBtnStyle}"
                                        Click="AddStatusEffect_Click"/>
                            </Grid>

                            <!-- Level / Chance / Turns -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="52"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Status Level:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="StatusLevelCombo"
                                          Grid.Column="1" Height="30"
                                          Background="#120C06" Foreground="#D4C5A9"
                                          BorderBrush="#5C3A1E"
                                          FontFamily="Georgia" FontSize="11"
                                          VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="CHANCE %:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="12,0,8,0"/>
                                <TextBox x:Name="StatusChanceInput" Grid.Column="4"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="100"/>
                                <TextBlock Grid.Column="6" Text="TURNS:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="12,0,8,0"/>
                                <TextBox x:Name="StatusTurnsInput" Grid.Column="7"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="3"/>
                            </Grid>

                            <!-- Status effects table -->
                            <Border BorderBrush="#3D2210" BorderThickness="1" CornerRadius="3">
                                <StackPanel>
                                    <Border Background="#0A0704" CornerRadius="3,3,0,0" Padding="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="66"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="STATUS" Style="{StaticResource TH}"/>
                                            <TextBlock Grid.Column="1" Text="TURNS"  Style="{StaticResource TH}"/>
                                            <TextBlock Grid.Column="2" Text="CHANCE" Style="{StaticResource TH}"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl x:Name="StatusEffectsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#1E1208" BorderThickness="0,0,0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#160F07"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                            <ColumnDefinition Width="66"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"  Style="{StaticResource TD}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Turns}"        Style="{StaticResource TD}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ChanceDisplay}" Style="{StaticResource TD}"/>
                                                        <Button    Grid.Column="3"
                                                                   Style="{StaticResource RemoveBtnStyle}"
                                                                   Tag="{Binding}"
                                                                   Click="RemoveStatusEffect_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- =================================== -->
                    <!--              STAT SECTION           -->
                    <!-- =================================== -->
                    <Border Style="{StaticResource SectionPanel}">
                        <StackPanel>
                            <TextBlock Text="STAT" Style="{StaticResource SectionHeader}"/>

                            <!-- Apply / Cleanse -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="StatApplyRb"
                                             Content="Apply"
                                             GroupName="StatMode"
                                             IsChecked="True"
                                             Style="{StaticResource DarkRadio}"/>
                                <RadioButton x:Name="StatCleanseRb"
                                             Content="○ Cleanse"
                                             GroupName="StatMode"
                                             Style="{StaticResource DarkRadio}"/>
                            </StackPanel>

                            <!-- Stat selector + Add -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Stat:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="StatCombo"
                                          Grid.Column="1" Height="30"
                                          Background="#120C06" Foreground="#D4C5A9"
                                          BorderBrush="#5C3A1E"
                                          FontFamily="Georgia" FontSize="11"
                                          DisplayMemberPath="Name"
                                          VerticalContentAlignment="Center"/>
                                <Button Grid.Column="3" Content="⊕"
                                        Style="{StaticResource AddBtnStyle}"
                                        Click="AddStatEffect_Click"/>
                            </Grid>

                            <!-- Chance / Turns -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="*CHANCE %:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="12,0,8,0"/>
                                <TextBox x:Name="StatChanceInput" Grid.Column="1"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="100"/>
                                <TextBlock Grid.Column="3" Text="*TURNS:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="12,0,8,0"/>
                                <TextBox x:Name="StatTurnsInput" Grid.Column="4"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="1"/>
                            </Grid>

                            <!-- Modifier / Min flat / Max flat -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Modifier %:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,8,0"/>
                                <TextBox x:Name="StatModifierInput" Grid.Column="1"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="0"/>
                                <TextBlock Grid.Column="3" Text="Min flat:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="10,0,8,0"/>
                                <TextBox x:Name="StatMinFlatInput" Grid.Column="4"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="0"/>
                                <TextBlock Grid.Column="6" Text="Max flat:"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="10,0,8,0"/>
                                <TextBox x:Name="StatMaxFlatInput" Grid.Column="7"
                                         Style="{StaticResource DarkInput}"
                                         Height="30" Text="0"/>
                            </Grid>

                            <!-- Stat effects table -->
                            <Border BorderBrush="#3D2210" BorderThickness="1" CornerRadius="3">
                                <StackPanel>
                                    <Border Background="#0A0704" CornerRadius="3,3,0,0" Padding="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="66"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="STAT"   Style="{StaticResource TH}"/>
                                            <TextBlock Grid.Column="1" Text="TURNS"  Style="{StaticResource TH}"/>
                                            <TextBlock Grid.Column="2" Text="CHANCE" Style="{StaticResource TH}"/>
                                            <TextBlock Grid.Column="3" Text="MULT"   Style="{StaticResource TH}"/>
                                        </Grid>
                                    </Border>
                                    <ItemsControl x:Name="StatEffectsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#1E1208" BorderThickness="0,0,0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#160F07"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="66"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"     Style="{StaticResource TD}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Turns}"           Style="{StaticResource TD}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ChanceDisplay}"   Style="{StaticResource TD}"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding ModifierDisplay}" Style="{StaticResource TD}"/>
                                                        <Button    Grid.Column="4"
                                                                   Style="{StaticResource RemoveBtnStyle}"
                                                                   Tag="{Binding}"
                                                                   Click="RemoveStatEffect_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ====== FOOTER / SAVE ====== -->
            <Border Grid.Row="2"
                    Background="#0A0704"
                    CornerRadius="0,0,6,6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="22,0">
                    <TextBlock Text="* REQUIRED FIELDS"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Georgia" FontSize="10"
                               VerticalAlignment="Center"
                               Opacity="0.4"/>
                    <Button Content="  ✦  SAVE  ✦  "
                            Style="{StaticResource ActionButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="170" Height="36"
                            Click="SaveItem_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#C8922A"/>
                        </Button.Foreground>
                        <Button.FontSize>13</Button.FontSize>
                        <Button.FontFamily>Georgia</Button.FontFamily>
                        <Button.Effect>
                            <DropShadowEffect Color="#C8922A" BlurRadius="10"
                                              ShadowDepth="0" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>