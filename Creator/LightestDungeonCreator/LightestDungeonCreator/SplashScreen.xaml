<Window x:Class="LightestDungeonCreator.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LightestDungeonCreator"
        mc:Ignorable="d"
        Title="SplashScreen"
        Height="620" Width="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundBrush"      Color="#0E0A08"/>
        <SolidColorBrush x:Key="PanelBrush"           Color="#1A1209"/>
        <SolidColorBrush x:Key="BorderBrush"          Color="#5C3A1E"/>
        <SolidColorBrush x:Key="GoldBrush"            Color="#C8922A"/>
        <SolidColorBrush x:Key="GoldDimBrush"         Color="#8A6015"/>
        <SolidColorBrush x:Key="CrimsonBrush"         Color="#8B1A1A"/>
        <SolidColorBrush x:Key="MutedBrush"           Color="#7A6A5A"/>
        <SolidColorBrush x:Key="TextBrush"            Color="#D4C5A9"/>

        <!-- Card border style -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background"       Value="#1A1209"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Main action button base -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#1F1208"/>
            <Setter Property="BorderBrush"  Value="{StaticResource GoldDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontFamily"   Value="Georgia"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exit button -->
        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Txt"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Txt" Property="Foreground" Value="#CC3333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer container with outer glow -->
    <Border CornerRadius="6" BorderThickness="1" BorderBrush="#3D2210">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0E0A08" Offset="0"/>
                <GradientStop Color="#120C08" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <!-- Title bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="40"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ── -->
            <Border Grid.Row="0"
                    Background="#0A0704"
                    CornerRadius="6,6,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="✦  DARKEST DUNGEON  —  REGISTRE"
                               Foreground="{StaticResource GoldDimBrush}"
                               FontFamily="Georgia"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Button Content="✕"
                            Style="{StaticResource ExitButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="ExitButton_Click"/>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="50,20,50,20">

                <!-- Decorative top rule -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                               Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                    <TextBlock Grid.Column="1" Text="  ☽ ✦ ☾  " 
                               Foreground="{StaticResource GoldDimBrush}"
                               FontSize="14" Margin="10,0"/>
                    <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                               Fill="{StaticResource GoldDimBrush}" Opacity="0.5"/>
                </Grid>

                <!-- Title -->
                <TextBlock Text="CREATOR"
                           Foreground="{StaticResource GoldBrush}"
                           FontFamily="Georgia"
                           FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#C8922A" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="Benvingut a les tenebres. Tria el teu camí."
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Georgia"
                           FontSize="13"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Two main buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Crear Personatge ── -->
                    <Button Grid.Column="0"
                            Style="{StaticResource ActionButtonStyle}"
                            Height="180"
                            Click="CreateCharacter_Click">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Icon area -->
                            <Border Background="#140C04"
                                    BorderBrush="{StaticResource GoldDimBrush}"
                                    BorderThickness="1"
                                    CornerRadius="50"
                                    Width="72" Height="72"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <TextBlock Text="⚔"
                                           FontSize="30"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource GoldBrush}"/>
                            </Border>

                            <TextBlock Text="CREAR PERSONATGE"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Georgia"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Forja un nou guerrer&#x0a;per a la foscor"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Georgia"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <!-- ── Crear Habilitat ── -->
                    <Button Grid.Column="2"
                            Style="{StaticResource ActionButtonStyle}"
                            Height="180"
                            Click="CreateSkill_Click">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Icon area -->
                            <Border Background="#140C04"
                                    BorderBrush="{StaticResource GoldDimBrush}"
                                    BorderThickness="1"
                                    CornerRadius="50"
                                    Width="72" Height="72"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <TextBlock Text="✦"
                                           FontSize="30"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource GoldBrush}"/>
                            </Border>

                            <TextBlock Text="CREAR HABILITAT"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontFamily="Georgia"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Dissenya poders i&#x0a;arts de combat"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Georgia"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Decorative bottom rule -->
                <Grid Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                               Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                    <TextBlock Grid.Column="1" Text="  ✦  "
                               Foreground="{StaticResource GoldDimBrush}"
                               FontSize="10" Margin="6,0" Opacity="0.5"/>
                    <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                               Fill="{StaticResource GoldDimBrush}" Opacity="0.3"/>
                </Grid>

            </StackPanel>

            <!-- ── Footer ── -->
            <Border Grid.Row="2"
                    Background="#0A0704"
                    CornerRadius="0,0,6,6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="© Darkest Dungeon Registry  —  Tots els drets reservats"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Georgia"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.6"/>
            </Border>
        </Grid>
    </Border>
</Window>
